# 统一 OCR 代理运行时配置（示例，复制为 .env 后修改）

# ---------- 服务自身 ----------
HOST=0.0.0.0
PORT=8088
WORKERS=1
REQUEST_TIMEOUT=180

# ---------- GLM-OCR（llama.cpp VLM，本机 8089）----------
GLM_OCR_ENABLED=1
GLM_OCR_API_HOST=127.0.0.1
GLM_OCR_API_PORT=8089
GLM_OCR_LAYOUT_DEVICE=cuda

# ---------- Unlimited-OCR（Docker 容器，主机 8090）----------
UNLIMITED_OCR_ENABLED=1
UNLIMITED_OCR_URL=http://localhost:8090
UNLIMITED_OCR_PARSE_PATH=/parse
UNLIMITED_OCR_HEALTH_PATH=/health

# ---------- PaddleOCR-VL（Docker 容器，主机 8091）----------
PADDLEOCR_VL_ENABLED=1
PADDLEOCR_VL_URL=http://localhost:8091
PADDLEOCR_VL_PARSE_PATH=/parse
PADDLEOCR_VL_HEALTH_PATH=/health
