.env
.env.local
.env.*.local
*.secret
*.key

# ===== Python =====
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.python-version

# ===== 模型与缓存（体积大，运行时下载） =====
.cache/
models/
*.gguf
*.bin
*.safetensors
*.onnx

# ===== 日志与临时文件 =====
*.log
logs/
